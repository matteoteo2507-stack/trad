# Template variabili ambiente. Copia questo file in `.env` e riempi i valori.
# Il file `.env` NON deve essere committato (vedi .gitignore).

# === LLM PROVIDERS (per il consensus layer Stage 4) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Provider locale (Ollama) — di default localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# === DATA SOURCES ===
# yfinance non richiede chiave (usato dal notebook V6.0).
# financialdatasets.ai (usato da ai-hedge-fund) — opzionale, alternativa a yfinance.
FINANCIAL_DATASETS_API_KEY=

# === BROKER: Interactive Brokers ===
# IBKR usa autenticazione via TWS/Gateway. Imposta porta locale.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_PAPER_MODE=true

# === BROKER: Alpaca (paper trading USA) ===
# Crea account su alpaca.markets → Paper Trading → Generate API Keys.
# Paper URL: https://paper-api.alpaca.markets/v2 — Live URL: https://api.alpaca.markets/v2
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets/v2

# === BROKER: MetaTrader 5 ===
# MT5 usa login/password/server del broker. 3 demo possibili.
MT5_DEMO1_LOGIN=
MT5_DEMO1_PASSWORD=
MT5_DEMO1_SERVER=
MT5_DEMO2_LOGIN=
MT5_DEMO2_PASSWORD=
MT5_DEMO2_SERVER=
MT5_DEMO3_LOGIN=
MT5_DEMO3_PASSWORD=
MT5_DEMO3_SERVER=

# === BROKER: Crypto ===
# Binance Spot Testnet — paper automatico via API. https://testnet.binance.vision
# Login con GitHub, genera API key dedicate testnet (NON le mainnet).
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Bybit Testnet — paper automatico (spot + perpetual). https://testnet.bybit.com
# Account separato dal mainnet, API key dedicate testnet.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# Coinbase — niente paper automatico (sandbox dismesso 2024).
# Tenuto come stub: usabile solo in mainnet con size minime per Stage 6.
COINBASE_API_KEY=
COINBASE_API_SECRET=

# === NOTIFIER: Telegram ===
# Crea il bot via @BotFather, ottieni il token.
# Per il chat_id: manda un messaggio al bot e poi GET https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === WORLDMONITOR (Stage 5) ===
WORLDMONITOR_API_BASE=
WORLDMONITOR_API_KEY=

# === LOGGING ===
LOG_LEVEL=INFO
LOG_DIR=./logs
